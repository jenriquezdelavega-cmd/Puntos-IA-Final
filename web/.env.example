# ── Required ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/puntoia"

# ── App Settings ──────────────────────────────────────────
# Master admin panel credentials (development defaults shown in app/lib/master-auth.ts)
MASTER_USERNAME="master_root_puntoia"
MASTER_PASSWORD="G9v!2Qp#7Lm@4Xz%8Ta$1Nd"
MASTER_TOTP_SECRET="N5YGK3TTONWCA4TBNZSCALLCMFZWKNRUEAZDAID4EB2HEIBNMQQCOPJLF4TSA7BAMN2XIIBNMMYS2MZS"
# Optional: Base32 TOTP secret for Microsoft/Google Authenticator.
# If set, master endpoints require `masterOtp` (6-digit code).


# Set to "false" to disable prelaunch lead-capture mode and show the full app
NEXT_PUBLIC_PRELAUNCH_MODE="false"

# Public-facing URL (required for Apple Wallet pass QR codes and webservice callbacks)
# PUBLIC_BASE_URL="https://your-app.vercel.app"

# ── Secrets (recommended for production) ──────────────────
# Secret for signing customer pass tokens (falls back to dev default if unset)
# PASS_TOKEN_SECRET=""

# Secret for QR code token signing/verification
# QR_TOKEN_SECRET=""

# Secret for user session token signing/verification (used by /api/user/update)
# USER_SESSION_SECRET=""

# Secret for tenant/admin session token signing/verification
# TENANT_SESSION_SECRET=""

# SMTP transactional email (required for welcome/reset/redeem confirmations)
# SMTP_HOST="smtpout.secureserver.net"
# SMTP_PORT="465"
# SMTP_SECURE="true"
# SMTP_USER="contacto@puntoia.mx"
# SMTP_PASS="your_smtp_password"
# EMAIL_FROM="Punto IA <contacto@puntoia.mx>"
# EMAIL_REPLY_TO="contacto@puntoia.mx"
# aliases also supported: SMTP_USERNAME/SMTP_PASSWORD or MAIL_HOST/MAIL_PORT/MAIL_USER/MAIL_PASS

# ── Apple Wallet (optional — only needed for .pkpass generation) ──
# APPLE_P12_BASE64=""
# APPLE_P12_PASSWORD=""
# APPLE_PASS_TYPE_ID=""
# APPLE_TEAM_ID=""
# APPLE_WALLET_AUTH_SECRET=""
# APPLE_APNS_HOST=""
# APPLE_APNS_USE_SANDBOX="true"

# ── Google Wallet (optional — only needed for Google passes) ──
# GOOGLE_WALLET_ISSUER_ID=""
# GOOGLE_WALLET_SA_B64=""
# Optional: if your approved class is not "<issuer>.LOYALTY"
# GOOGLE_WALLET_CLASS_ID=""

# ── Misc (optional) ──────────────────────────────────────
# Path to OpenSSL binary (auto-detected if not set)
# OPENSSL_BIN=""
