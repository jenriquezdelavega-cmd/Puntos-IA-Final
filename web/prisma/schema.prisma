generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id             String       @id @default(uuid())
  name           String
  slug           String       @unique
  username       String?      @unique
  password       String?
  prize          String       @default("Premio Sorpresa")
  requiredVisits Int          @default(10)
  rewardPeriod   RewardPeriod @default(OPEN)

  // 🔓 SIN UNIQUE POR AHORA PARA PASAR EL DEPLOY
  codePrefix String?

  lat       Float?  @default(19.4326)
  lng       Float?  @default(-99.1332)
  address   String? @default("Dirección pendiente")
  instagram String?
  logoData  String?
  isActive  Boolean @default(true)
  coalitionOptIn Boolean @default(false) @map("coalition_opt_in")
  coalitionDiscountPercent Int @default(0) @map("coalition_discount_percent")
  coalitionProduct String @default("") @map("coalition_product")
  ticketControlEnabled Boolean @default(false) @map("ticket_control_enabled")

  createdAt DateTime @default(now())

  users       TenantUser[]
  memberships Membership[]
  dailyCodes  DailyCode[]
  redemptions Redemption[]
  walletStyle TenantWalletStyle?
  pushLogs    TenantPushLog[]
  coalitionRewards CoalitionReward[]
  loyaltyMilestones LoyaltyMilestone[]
}

model TenantUser {
  id             String      @id @default(uuid())
  name           String
  phone          String
  email          String
  username       String      @unique
  password       String
  mustChangePassword Boolean @default(false) @map("must_change_password")
  passwordChangedAt DateTime? @map("password_changed_at")
  role           String
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  generatedCodes DailyCode[] @relation("DailyCodeGeneratedBy")
  passwordResetTokens TenantUserPasswordResetToken[]
}

model TenantUserPasswordResetToken {
  id           String     @id @default(uuid())
  tenantUserId String     @map("tenant_user_id")
  tenantUser   TenantUser @relation(fields: [tenantUserId], references: [id], onDelete: Cascade)
  tokenHash    String     @unique @map("token_hash")
  expiresAt    DateTime   @map("expires_at")
  usedAt       DateTime?  @map("used_at")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@index([tenantUserId])
  @@index([expiresAt])
  @@map("tenant_user_password_reset_tokens")
}

model User {
  id          String       @id @default(uuid())
  phone       String       @unique
  email       String?
  password    String       @default("1234")
  name        String?
  gender      String?
  birthDate   DateTime?
  createdAt   DateTime     @default(now())
  memberships Membership[]
  redemptions Redemption[]
  passwordResetTokens PasswordResetToken[]
  challengeProgress CustomerChallengeProgress[]
  coalitionRewardUnlocks CustomerCoalitionReward[]
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Membership {
  id            String       @id @default(uuid())
  currentVisits Int          @default(0)
  periodKey     String       @default("OPEN")
  periodType    RewardPeriod @default(OPEN)
  totalVisits   Int          @default(0)
  lastVisitAt   DateTime?
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  visits        Visit[]

  @@unique([tenantId, userId])
}

model DailyCode {
  id        String   @id @default(uuid())
  code      String
  day       String // YYYY-MM-DD (para reglas/uniques)
  validDate DateTime @default(now())
  isActive  Boolean  @default(true)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  generatedById String
  generatedBy   TenantUser @relation("DailyCodeGeneratedBy", fields: [generatedById], references: [id], onDelete: Cascade)

  visits Visit[]

  @@unique([tenantId, generatedById, day])
}

model Visit {
  id             String   @id @default(uuid())
  visitedAt      DateTime @default(now())
  purchaseAmount Float    @default(0) @map("purchase_amount")
  ticketNumber   String?  @map("ticket_number")

  // para evitar múltiples scans en el mismo día por negocio
  visitDay String // YYYY-MM-DD
  tenantId String

  membershipId String
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  dailyCodeId String
  dailyCode   DailyCode @relation(fields: [dailyCodeId], references: [id])

  @@unique([membershipId, tenantId, visitDay])
}

model Redemption {
  id        String   @id @default(uuid())
  code      String
  rewardSnapshot String? @map("reward_snapshot")
  isUsed    Boolean  @default(false)
  usedAt    DateTime?
  createdAt DateTime @default(now())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  coalitionRewardUnlockId String? @unique @map("coalition_reward_unlock_id")
  coalitionRewardUnlock   CustomerCoalitionReward? @relation(fields: [coalitionRewardUnlockId], references: [id], onDelete: SetNull)
  loyaltyMilestoneId String? @map("loyalty_milestone_id")
  loyaltyMilestone   LoyaltyMilestone? @relation(fields: [loyaltyMilestoneId], references: [id], onDelete: SetNull)
}


model Challenge {
  id               String        @id @default(uuid())
  title            String
  description      String
  challengeType    ChallengeType @map("challenge_type")
  targetValue      Int           @map("target_value")
  timeWindow       Int           @map("time_window")
  rewardCampaignId String?       @map("reward_campaign_id")
  rewardCampaign   CoalitionReward? @relation(fields: [rewardCampaignId], references: [id], onDelete: SetNull)
  active           Boolean       @default(true)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  customerProgress CustomerChallengeProgress[]

  @@index([active])
  @@map("challenges")
}

model CustomerChallengeProgress {
  customerId    String                  @map("customer_id")
  challengeId   String                  @map("challenge_id")
  progressValue Int                     @default(0) @map("progress_value")
  status        ChallengeProgressStatus @default(IN_PROGRESS)
  completedAt   DateTime?               @map("completed_at")
  updatedAt     DateTime                @updatedAt @map("updated_at")
  createdAt     DateTime                @default(now()) @map("created_at")

  customer  User      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@id([customerId, challengeId])
  @@index([status])
  @@map("customer_challenge_progress")
}

model CoalitionReward {
  id              String    @id @default(uuid())
  businessId      String    @map("business_id")
  title           String
  rewardType      String    @map("reward_type")
  rewardValue     String    @map("reward_value")
  redemptionLimit Int       @default(1) @map("redemption_limit")
  expiresAt       DateTime? @map("expires_at")
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  business   Tenant                   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  challenges Challenge[]
  unlockedBy CustomerCoalitionReward[]

  @@index([businessId])
  @@map("coalition_rewards")
}

model CustomerCoalitionReward {
  id         String    @id @default(uuid())
  customerId String    @map("customer_id")
  rewardId   String    @map("reward_id")
  unlockedAt DateTime  @default(now()) @map("unlocked_at")
  requestedAt DateTime? @map("requested_at")
  redeemedAt DateTime? @map("redeemed_at")

  customer User            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  reward   CoalitionReward @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  redemption Redemption?

  @@unique([customerId, rewardId])
  @@index([customerId])
  @@map("customer_coalition_rewards")
}

model AppleWalletRegistration {
  serialNumber            String   @map("serial_number")
  passTypeIdentifier      String   @map("pass_type_identifier")
  deviceLibraryIdentifier String   @map("device_library_identifier")
  pushToken               String   @map("push_token")
  authToken               String   @map("auth_token")
  updatedAt               DateTime @default(now()) @map("updated_at")
  createdAt               DateTime @default(now()) @map("created_at")

  @@id([serialNumber, passTypeIdentifier, deviceLibraryIdentifier])
  @@map("apple_wallet_registrations")
}

model TenantPushLog {
  id        String   @id @default(uuid())
  tenantId  String
  message   String
  devices   Int      @default(0)
  sentAt    DateTime @default(now()) @map("sent_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_push_logs")
}

model LoyaltyMilestone {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  visitTarget Int      @map("visit_target")
  reward      String
  emoji       String   @default("🎁")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  redemptions Redemption[]

  @@unique([tenantId, visitTarget])
  @@index([tenantId])
  @@map("loyalty_milestones")
}

model TenantWalletStyle {
  tenantId       String   @id @map("tenant_id")
  backgroundColor String  @default("rgb(31,41,55)") @map("background_color")
  foregroundColor String  @default("rgb(255,255,255)") @map("foreground_color")
  labelColor      String  @default("rgb(191,219,254)") @map("label_color")
  stripImageData  String   @default("") @map("strip_image_data")
  lastPushMessage String   @default("") @map("last_push_message")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")
  createdAt       DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_wallet_styles")
}

enum RewardPeriod {
  OPEN
  MONTHLY
  QUARTERLY
  SEMESTER
  ANNUAL
}

enum ChallengeType {
  VISIT_COUNT
  DISTINCT_BUSINESSES
}

enum ChallengeProgressStatus {
  IN_PROGRESS
  COMPLETED
}
